# Copy this file to .env and fill in your keys

# MapTiler — free tier: 100k tile loads/month, no credit card required
# Get a key at https://cloud.maptiler.com/account/keys/
VITE_MAPTILER_API_KEY=your_maptiler_api_key_here

# Firebase — get from console.firebase.google.com
# Enable: Authentication (Google provider), Firestore, Cloud Messaging
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key_for_push_notifications
