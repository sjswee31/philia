# Copy this file to .env and fill in your keys
# ⚠️  COST WARNING: Google Maps JS API = $7/1k map loads, Places API = $32/1k searches
# Both are covered by the $200/month free credit for small demos.
# I will warn you before any production deployment that could exceed the free tier.

# Google Maps — get from console.cloud.google.com
# Enable: Maps JavaScript API, Places API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase — get from console.firebase.google.com
# Enable: Authentication (Google provider), Firestore, Cloud Messaging
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key_for_push_notifications
